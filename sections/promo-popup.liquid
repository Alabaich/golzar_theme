{% if template.name == 'product' %}
<style>
  .promo-popup-overlay {
    position: fixed;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    z-index: 99999;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 16px;
    box-sizing: border-box;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  }

  .promo-popup-container {
    background: #ffffff;
    width: 100%;
    max-width: 560px;
    max-height: calc(100vh - 32px);
    display: flex;
    flex-direction: column;
    position: relative;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.25);
    border-radius: 14px;
    overflow: hidden;
  }

  /* Close button */
  .promo-popup-close-btn {
    position: absolute;
    top: 12px;
    right: 12px;
    cursor: pointer;
    color: #555;
    background: rgba(255,255,255,0.95);
    border: none;
    z-index: 10;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 8px rgba(0,0,0,0.15);
    transition: background 0.15s ease, transform 0.15s ease;
    -webkit-appearance: none;
    appearance: none;
    padding: 0;
    flex-shrink: 0;
  }
  .promo-popup-close-btn:hover {
    background: #f0f0f0;
    transform: scale(1.08);
  }

  .promo-popup-image-wrapper {
    width: 100%;
    height: 180px;
    flex-shrink: 0;
    background-color: #d5dce8;
    background-image: url('https://cdn.shopify.com/s/files/1/0848/7193/8321/files/toto-collection-image-ultramax-washlet.webp?v=1768631791');
    background-size: cover;
    background-position: center;
  }

  /* Content */
  .promo-popup-content-wrapper {
    padding: 28px 32px 32px;
    box-sizing: border-box;
    overflow-y: auto;
  }

  .promo-popup-badge {
    display: inline-block;
    background: #eef1f9;
    color: #1a3673;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 20px;
    margin-bottom: 12px;
  }

  .promo-popup-title {
    color: #1a3673;
    font-size: 24px;
    font-weight: 700;
    margin: 0 0 8px 0;
    line-height: 1.2;
    letter-spacing: -0.3px;
  }

  .promo-popup-description {
    color: #555;
    font-size: 14px;
    margin: 0 0 20px 0;
    line-height: 1.55;
  }

  .promo-popup-fields {
    display: flex;
    gap: 10px;
    margin-bottom: 10px;
  }

  .promo-popup-input-field {
    width: 100%;
    padding: 12px 14px;
    border: 1.5px solid #e0e0e0;
    border-radius: 8px;
    box-sizing: border-box;
    font-size: 14px;
    outline: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    color: #222;
    background: #fafafa;
  }
  .promo-popup-input-field:focus {
    border-color: #1a3673;
    box-shadow: 0 0 0 3px rgba(26,54,115,0.1);
    background: #fff;
  }
  .promo-popup-input-field::placeholder {
    color: #aaa;
  }

  .promo-popup-submit-btn {
    width: 100%;
    padding: 14px;
    margin-top: 4px;
    background: #1a3673;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s ease, transform 0.1s ease;
    letter-spacing: 0.01em;
  }
  .promo-popup-submit-btn:hover {
    background: #122856;
  }
  .promo-popup-submit-btn:active {
    transform: scale(0.98);
  }

  .promo-popup-fine-print {
    color: #aaa;
    font-size: 11px;
    margin: 10px 0 0 0;
    text-align: center;
  }

  /* Success state */
  .promo-popup-success {
    text-align: center;
    padding: 8px 0 4px;
  }
  .promo-popup-success-icon {
    width: 48px;
    height: 48px;
    background: #eef7ee;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 12px;
  }
  .promo-popup-success p {
    color: #333;
    font-size: 15px;
    font-weight: 600;
    margin: 0;
  }
  .promo-popup-success span {
    color: #777;
    font-size: 13px;
    display: block;
    margin-top: 4px;
  }

  /* Mobile */
  @media (max-width: 480px) {
    .promo-popup-overlay {
      padding: 22px 20px calc(70px + env(safe-area-inset-bottom, 0px));
      align-items: flex-end;
    }
    .promo-popup-container {
      max-width: 100%;
      border-radius: 16px 16px 0 0;
      max-height: 92vh;
    }
    .promo-popup-image-wrapper {
      height: 150px;
    }
    .promo-popup-content-wrapper {
      padding: 22px 20px 28px;
    }
    .promo-popup-fields {
      flex-direction: column;
      gap: 8px;
    }
    .promo-popup-title {
      font-size: 22px;
    }
  }
</style>

<div id="promo-popup-overlay" class="promo-popup-overlay" role="dialog" aria-modal="true" aria-labelledby="promo-popup-heading">
  <div class="promo-popup-container" id="promo-popup-container">

    <div class="promo-popup-image-wrapper" aria-hidden="true"></div>

    <div class="promo-popup-content-wrapper">
      <span class="promo-popup-badge">Exclusive offer</span>
      <h2 class="promo-popup-title" id="promo-popup-heading">Planning a renovation?</h2>
      <p class="promo-popup-description">Get the best deals on bathroom &amp; kitchen essentials — straight to your inbox.</p>

      {% form 'customer', id: 'promo-popup-newsletter-form' %}
        {% if form.posted_successfully? %}
          <div class="promo-popup-success">
            <div class="promo-popup-success-icon">
              <svg width="22" height="22" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M4 11L9 16L18 6" stroke="#2d8a3e" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <p>You're subscribed!</p>
            <span>We'll be in touch with our best offers.</span>
          </div>
          <script>sessionStorage.setItem('promoPopupInteracted', 'true');</script>
        {% else %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="promo-popup-fields">
            <input type="text" name="contact[first_name]" class="promo-popup-input-field" placeholder="First name" autocomplete="given-name" required>
            <input type="text" name="contact[last_name]" class="promo-popup-input-field" placeholder="Last name" autocomplete="family-name" required>
          </div>
          <input type="email" name="contact[email]" class="promo-popup-input-field" placeholder="Email address" autocomplete="email" required>
          <button type="submit" class="promo-popup-submit-btn">Get the deals</button>
          <p class="promo-popup-fine-print">Unsubscribe any time.</p>
        {% endif %}
      {% endform %}
    </div>

    <button id="promo-popup-close-btn" class="promo-popup-close-btn" aria-label="Close">
      <svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M11 1L1 11M1 1L11 11" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    var overlay = document.getElementById('promo-popup-overlay');
    var container = document.getElementById('promo-popup-container');
    var closeBtn = document.getElementById('promo-popup-close-btn');
    var storageKey = 'promoPopupShownPerSession';

    function openPopup() {
      overlay.style.display = 'flex';
      document.body.style.overflow = 'hidden';
    }

    function closePopup() {
      overlay.style.display = 'none';
      document.body.style.overflow = '';
    }

    // Close on backdrop click (click outside the popup container)
    overlay.addEventListener('click', function (e) {
      if (!container.contains(e.target)) {
        closePopup();
      }
    });

    // Close on X button
    closeBtn.addEventListener('click', closePopup);

    // Close on Escape key
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && overlay.style.display === 'flex') {
        closePopup();
      }
    });

    // Show logic
    if (window.location.search.indexOf('customer_posted=true') > -1) {
      openPopup();
      sessionStorage.setItem('promoPopupInteracted', 'true');
    } else if (!sessionStorage.getItem(storageKey) && !sessionStorage.getItem('promoPopupInteracted')) {
      setTimeout(openPopup, 4000);
      sessionStorage.setItem(storageKey, 'true');
    }
  });
</script>
{% endif %}
