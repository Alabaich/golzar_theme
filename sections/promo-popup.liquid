{% if template.name == 'product' %}
<style>
  .promo-popup-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.65);
    backdrop-filter: blur(3px);
    z-index: 99999;
    display: none;
    align-items: center;
    justify-content: center;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  }

  .promo-popup-container {
    background-color: #ffffff;
    width: 800px;
    max-width: 90%;
    display: flex;
    align-items: stretch;
    position: relative;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
    border-radius: 12px;
    overflow: hidden;
  }

  .promo-popup-close-btn {
    position: absolute;
    top: 15px;
    right: 15px;
    font-size: 22px;
    line-height: 1;
    cursor: pointer;
    color: #999;
    background: transparent;
    border: none;
    z-index: 2;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
  }

  .promo-popup-close-btn:hover {
    color: #333;
    background-color: #f0f0f0;
  }

  .promo-popup-image-wrapper {
    width: 45%;
    flex: 0 0 45%;
    background-color: #e9ecef;
    background-image: url('https://cdn.shopify.com/s/files/1/0848/7193/8321/files/toto-collection-image-ultramax-washlet.webp?v=1768631791');
    background-size: cover;
    background-position: center;
    min-height: 450px;
  }

  .promo-popup-content-wrapper {
    width: 55%;
    flex: 0 0 55%;
    padding: 60px 50px;
    box-sizing: border-box;
    text-align: left;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .promo-popup-title {
    color: #1a3673;
    font-size: 34px;
    font-weight: 700;
    margin: 0 0 12px 0;
    line-height: 1.15;
    letter-spacing: -0.5px;
  }

  .promo-popup-description {
    color: #444444;
    font-size: 15px;
    margin: 0 0 10px 0;
    line-height: 1.5;
  }

  .promo-popup-promise {
    color: #777777;
    font-size: 13px;
    margin: 0 0 25px 0;
  }

  .promo-popup-input-field {
    width: 100%;
    padding: 14px 16px;
    margin-bottom: 12px;
    border: 1px solid #dcdcdc;
    border-radius: 6px;
    box-sizing: border-box;
    font-size: 14px;
    outline: none;
    transition: all 0.2s ease;
  }

  .promo-popup-input-field:focus {
    border-color: #1a3673;
    box-shadow: 0 0 0 1px #1a3673;
  }

  .promo-popup-submit-btn {
    width: 100%;
    padding: 15px;
    margin-top: 8px;
    background-color: #1a3673;
    color: #ffffff;
    border: none;
    border-radius: 6px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.2s ease, transform 0.1s ease;
  }

  .promo-popup-submit-btn:hover {
    background-color: #122856;
  }

  .promo-popup-submit-btn:active {
    transform: scale(0.98);
  }

  @media (max-width: 768px) {
    .promo-popup-container {
      flex-direction: column;
      max-height: 90vh;
      overflow-y: auto;
      border-radius: 12px;
    }
    .promo-popup-image-wrapper {
      width: 100%;
      flex: 0 0 auto;
      height: 220px;
      min-height: 220px;
    }
    .promo-popup-content-wrapper {
      width: 100%;
      flex: 0 0 auto;
      padding: 35px 25px;
    }
    .promo-popup-title {
      font-size: 28px;
    }
  }
</style>

<div id="promo-popup-overlay" class="promo-popup-overlay">
  <div class="promo-popup-container">
    <button id="promo-popup-close-btn" class="promo-popup-close-btn" aria-label="Close">&times;</button>

    <div class="promo-popup-image-wrapper">&nbsp;</div>

    <div class="promo-popup-content-wrapper">
      <h2 class="promo-popup-title">Renovation<br>plans ahead?</h2>
      <p class="promo-popup-description">Subscribe to receive our best deals on bathroom and kitchen essentials.</p>
      <p class="promo-popup-promise">Only the good stuff, we promise.</p>

      {% form 'customer', id: 'promo-popup-newsletter-form' %}
        {% if form.posted_successfully? %}
          <p style="color: #28a745; font-weight: 600; font-size: 15px; text-align: center; padding: 10px 0;">Thank you for subscribing!</p>
          <script>
            sessionStorage.setItem('promoPopupInteracted', 'true');
          </script>
        {% else %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <input type="text" name="contact[first_name]" class="promo-popup-input-field" placeholder="First Name" required>
          <input type="text" name="contact[last_name]" class="promo-popup-input-field" placeholder="Last Name" required>
          <input type="email" name="contact[email]" class="promo-popup-input-field" placeholder="Email" required>
          <button type="submit" class="promo-popup-submit-btn">Sign me up!</button>
        {% endif %}
      {% endform %}
    </div>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    var overlay = document.getElementById('promo-popup-overlay');
    var closeButton = document.getElementById('promo-popup-close-btn');
    var storageKey = 'promoPopupShownPerSession';

    if (window.location.search.indexOf('customer_posted=true') > -1) {
      overlay.style.display = 'flex';
      sessionStorage.setItem('promoPopupInteracted', 'true');
    } 
    else if (!sessionStorage.getItem(storageKey) && !sessionStorage.getItem('promoPopupInteracted')) {
      setTimeout(function() {
        overlay.style.display = 'flex';
        sessionStorage.setItem(storageKey, 'true');
      }, 4000);
    }

    closeButton.addEventListener('click', function() {
      overlay.style.display = 'none';
    });

    overlay.addEventListener('click', function(event) {
      if (event.target === overlay) {
        overlay.style.display = 'none';
      }
    });
  });
</script>
{% endif %}