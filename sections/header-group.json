        "custom_liquid": "{% if template.name == 'product' %}\n<style>\n  .promo-popup-overlay {\n    position: fixed;\n    top: 0; \n    left: 0; \n    width: 100%; \n    height: 100%;\n    background-color: rgba(0, 0, 0, 0.6);\n    z-index: 99999;\n    display: none;\n    align-items: center;\n    justify-content: center;\n    font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif;\n  }\n  \n  .promo-popup-container {\n    background-color: #ffffff;\n    width: 750px;\n    max-width: 90%;\n    display: flex;\n    position: relative;\n    box-shadow: 0 4px 20px rgba(0,0,0,0.15);\n  }\n  \n  .promo-popup-close-btn {\n    position: absolute;\n    top: 15px; \n    right: 15px;\n    font-size: 24px;\n    line-height: 1;\n    cursor: pointer;\n    color: #a0a0a0;\n    background: none;\n    border: none;\n    z-index: 2;\n    padding: 0;\n  }\n\n  .promo-popup-close-btn:hover {\n    color: #333;\n  }\n  \n  .promo-popup-image-wrapper {\n    width: 45%;\n    background-color: #e9ecef;\n    /* Replace the URL below with your actual image link */\n    background-image: url('https://cdn.shopify.com/s/files/1/0533/2089/files/placeholder-images-image_large.png');\n    background-size: cover;\n    background-position: center;\n  }\n  \n  .promo-popup-content-wrapper {\n    width: 55%;\n    padding: 50px 40px;\n    box-sizing: border-box;\n    text-align: left;\n  }\n  \n  .promo-popup-title {\n    color: #1a3673;\n    font-size: 32px;\n    font-weight: 700;\n    margin: 0 0 15px 0;\n    line-height: 1.1;\n  }\n  \n  .promo-popup-description {\n    color: #333333;\n    font-size: 14px;\n    margin: 0 0 15px 0;\n    line-height: 1.5;\n  }\n  \n  .promo-popup-promise {\n    color: #555555;\n    font-size: 13px;\n    margin: 0 0 25px 0;\n  }\n  \n  .promo-popup-input-field {\n    width: 100%;\n    padding: 12px 15px;\n    margin-bottom: 12px;\n    border: 1px solid #4a4a4a;\n    box-sizing: border-box;\n    font-size: 14px;\n    outline: none;\n  }\n\n  .promo-popup-input-field:focus {\n    border-color: #1a3673;\n  }\n  \n  .promo-popup-submit-btn {\n    width: 100%;\n    padding: 14px;\n    margin-top: 5px;\n    background-color: #1a3673;\n    color: #ffffff;\n    border: none;\n    font-size: 15px;\n    font-weight: 600;\n    cursor: pointer;\n    transition: background-color 0.2s ease;\n  }\n  \n  .promo-popup-submit-btn:hover {\n    background-color: #122856;\n  }\n  \n  @media (max-width: 768px) {\n    .promo-popup-container {\n      flex-direction: column;\n      max-height: 90vh;\n      overflow-y: auto;\n    }\n    .promo-popup-image-wrapper {\n      width: 100%;\n      height: 250px;\n    }\n    .promo-popup-content-wrapper {\n      width: 100%;\n      padding: 30px 20px;\n    }\n    .promo-popup-title {\n      font-size: 26px;\n    }\n  }\n</style>\n\n<div id=\"promo-popup-overlay\" class=\"promo-popup-overlay\">\n  <div class=\"promo-popup-container\">\n    <button id=\"promo-popup-close-btn\" class=\"promo-popup-close-btn\">&times;</button>\n    \n    <div class=\"promo-popup-image-wrapper\"></div>\n    \n    <div class=\"promo-popup-content-wrapper\">\n      <h2 class=\"promo-popup-title\">Renovation<br>plans ahead?</h2>\n      <p class=\"promo-popup-description\">Subscribe to receive our best deals on bathroom and kitchen essentials.</p>\n      <p class=\"promo-popup-promise\">Only the good stuff, we promise.</p>\n      \n      {% form 'customer', id: 'promo-popup-newsletter-form' %}\n        {% if form.posted_successfully? %}\n          <p style=\"color: green; font-weight: bold;\">Thank you for subscribing!</p>\n          <script>\n            sessionStorage.setItem('promoPopupInteracted', 'true');\n          </script>\n        {% else %}\n          <input type=\"hidden\" name=\"contact[tags]\" value=\"newsletter\">\n          <input type=\"text\" name=\"contact[first_name]\" class=\"promo-popup-input-field\" placeholder=\"First Name\" required>\n          <input type=\"text\" name=\"contact[last_name]\" class=\"promo-popup-input-field\" placeholder=\"Last Name\" required>\n          <input type=\"email\" name=\"contact[email]\" class=\"promo-popup-input-field\" placeholder=\"Email\" required>\n          <button type=\"submit\" class=\"promo-popup-submit-btn\">Sign me up!</button>\n        {% endif %}\n      {% endform %}\n    </div>\n  </div>\n</div>\n\n<script>\n  document.addEventListener(\"DOMContentLoaded\", function() {\n    var overlay = document.getElementById('promo-popup-overlay');\n    var closeButton = document.getElementById('promo-popup-close-btn');\n    var storageKey = 'promoPopupShownPerSession';\n\n    if (window.location.search.indexOf('customer_posted=true') > -1) {\n      overlay.style.display = 'flex';\n      sessionStorage.setItem('promoPopupInteracted', 'true');\n    } else if (!sessionStorage.getItem(storageKey) && !sessionStorage.getItem('promoPopupInteracted')) {\n      setTimeout(function() {\n        overlay.style.display = 'flex';\n        sessionStorage.setItem(storageKey, 'true');\n      }, 4000); \n    }\n\n    closeButton.addEventListener('click', function() {\n      overlay.style.display = 'none';\n    });\n\n    overlay.addEventListener('click', function(event) {\n      if (event.target === overlay) {\n        overlay.style.display = 'none';\n      }\n    });\n  });\n</script>\n{% endif %}",
